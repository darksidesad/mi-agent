# API Keys - Copy to .env and fill values
TAVILY_API_KEY=tvly-xxxxxxxxxx
OPENROUTER_API_KEY=sk-or-xxxxxxxxxx
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Model Configuration
OPENROUTER_MODEL=anthropic/claude-sonnet-4-20250514
OPENROUTER_FAST_MODEL=openai/gpt-4o-mini

# Pipeline Settings
MAX_LOOP_ITERATIONS=5
LOOP_TIMEOUT_SECONDS=600
QUALITY_THRESHOLD=8.0
MAX_COST_USD=0.10

# Qdrant Settings
QDRANT_COLLECTION=intelligence_briefs
QDRANT_SCORE_THRESHOLD=0.7
QDRANT_TOP_K=10

# Tavily Settings
TAVILY_SEARCH_DEPTH=advanced
TAVILY_MAX_RESULTS=5
TAVILY_DAYS=3

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO